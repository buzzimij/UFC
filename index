      <!-- FIGHT 1: Sterling vs Zalal -->
      <div class="fight-card">
        <div class="fight-header">
          <div>
            <div class="fight-label">Main Event · Featherweight · 5 Rounds</div>
            <div class="fight-matchup">Aljamain Sterling <span class="vs">vs.</span> Youssef Zalal</div>
